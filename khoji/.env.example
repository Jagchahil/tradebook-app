# Khoji environment. Copy to .env on the mini and fill in. NEVER commit the real .env.

# The restricted database role from schema.sql. Least privilege: this credential
# can only read and write knowledge_items, nothing else in the database. Use the
# Supabase connection string (Project Settings, Database) but swap the user and
# password for khoji_writer and the password you set in schema.sql. Keep sslmode.
# Example shape (host and project ref are yours):
#   postgres://khoji_writer:YOUR_STRONG_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
KHOJI_DB_URL=

# The Obsidian vault to write human readable notes into. Absolute path. Khoji
# writes into a "Khoji" folder inside it. Leave blank to skip Obsidian.
OBSIDIAN_VAULT=

# Distillation (the only part that costs Anthropic credit). Dormant by default.
# Turn on ONLY once credit is funded: set KHOJI_DISTILL=on and add the key below.
KHOJI_DISTILL=off
ANTHROPIC_API_KEY=

# Optional. Cap items processed per run (default 25). Model override if needed.
KHOJI_MAX_ITEMS=25
# KHOJI_MODEL=claude-haiku-4-5-20251001
