# Dependencies. NEVER commit these.
#
# This file used to contain ONLY the .env rules below. It got rsynced over the
# deploy repo's real .gitignore, and the next `git add -A` swept node_modules into
# the commit. node_modules holds binaries far over GitHub's 100 MB file limit (the
# Next SWC binary alone is ~116 MB), so the push was rejected outright. Keep this
# list complete: this file is synced, so a gap here silently breaks the repo.
node_modules/
.pnp
.pnp.js

# Build output
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Secrets. Never commit.
.env*
!.env*.example

# Vercel
.vercel

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Testing
coverage/

# OS and editor noise
.DS_Store
*.pem
.idea/
.vscode/

# Orphaned file handles from the Cowork FUSE mount, and 0 byte editor temp files.
# They are not source. They got committed once; never again.
.fuse_hidden*
XX*
